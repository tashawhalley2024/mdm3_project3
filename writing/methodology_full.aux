\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Leave-one-out jackknife for the composite coefficient (left column) and the apostasy coefficient (right column). The top row shows each of the 166 single-country-drop coefficients as a small dot, jittered vertically. The vertical solid line is the baseline coefficient from the full sample. The shaded band is the baseline $95\%$ confidence interval. The dashed line at zero is the sign-flip threshold. The bottom row shows the five countries whose removal moves the coefficient most. Results are written to \texttt  {results/loo\_jackknife.csv} (composite) and \texttt  {results/loo\_jackknife\_apostasy.csv} (apostasy).}}{21}{figure.caption.6}\protected@file@percent }
\newlabel{fig:loo}{{5}{21}{Leave-one-out jackknife for the composite coefficient (left column) and the apostasy coefficient (right column). The top row shows each of the 166 single-country-drop coefficients as a small dot, jittered vertically. The vertical solid line is the baseline coefficient from the full sample. The shaded band is the baseline $95\%$ confidence interval. The dashed line at zero is the sign-flip threshold. The bottom row shows the five countries whose removal moves the coefficient most. Results are written to \texttt {results/loo\_jackknife.csv} (composite) and \texttt {results/loo\_jackknife\_apostasy.csv} (apostasy)}{figure.caption.6}{}}
